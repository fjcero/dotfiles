#!/usr/bin/env bash
# packages/home/export - snapshot tracked dotfiles from $HOME (git + SSH client config only; never keys).

set -euo pipefail

# shellcheck source=../../packages/lib.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)/packages/lib.sh"

dotfiles_parse_output_arg "$@"
dotfiles_require_output_dir "$DOTFILES_OUTPUT_DIR"

copy_if() {
  local src="$1"
  local dest="$2"
  if [[ -e "$src" ]]; then
    mkdir -p "$(dirname "$dest")"
    cp -R "$src" "$dest"
  fi
}

copy_if "$HOME/.gitconfig" "$DOTFILES_OUTPUT_DIR/.gitconfig"
copy_if "$HOME/.gitignore_global" "$DOTFILES_OUTPUT_DIR/.gitignore_global"

if [[ -f "$HOME/.ssh/config" ]]; then
  mkdir -p "$DOTFILES_OUTPUT_DIR/.ssh"
  cp "$HOME/.ssh/config" "$DOTFILES_OUTPUT_DIR/.ssh/config"
fi

echo "home export: done -> $DOTFILES_OUTPUT_DIR"
