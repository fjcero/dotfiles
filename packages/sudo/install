#!/usr/bin/env bash
# packages/sudo/install - enable Touch ID for sudo (requires sudo).
# Reference: https://github.com/ghostty-org/ghostty/discussions/5358#discussioncomment-16449540

set -euo pipefail

pam_sudo_local="/etc/pam.d/sudo_local"

if [[ -f "$pam_sudo_local" ]] && grep -q '^auth.*pam_tid\.so' "$pam_sudo_local"; then
  echo "sudo install: Touch ID for sudo already enabled."
elif [[ -f /etc/pam.d/sudo_local.template ]]; then
  echo "sudo install: enabling Touch ID for sudo..."
  sudo cp /etc/pam.d/sudo_local.template "$pam_sudo_local"
  sudo sed -i '' 's/^#auth.*pam_tid\.so/auth       sufficient     pam_tid.so/' "$pam_sudo_local"
  echo "sudo install: done. Test with: sudo echo ok"
else
  echo "sudo install: /etc/pam.d/sudo_local.template not found; skipping." >&2
fi
