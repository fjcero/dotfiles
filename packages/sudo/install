#!/usr/bin/env bash
# packages/sudo/install - install drop-ins from packages/sudo/files (requires sudo).

set -euo pipefail

export DOTFILES_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
files_dir="$DOTFILES_ROOT/packages/sudo/files"

if [[ ! -d "$files_dir" ]]; then
  echo "sudo install: no files directory."
  exit 0
fi

installed=0
for f in "$files_dir"/*; do
  [[ -f "$f" ]] || continue
  base="$(basename "$f")"
  case "$base" in
    README.txt|*.md) continue ;;
  esac
  echo "Installing sudoers fragment: $base"
  sudo install -m 0440 "$f" "/etc/sudoers.d/$base"
  sudo visudo -cf "/etc/sudoers.d/$base"
  installed=1
done

if [[ "$installed" -eq 0 ]]; then
  echo "sudo install: no fragment files to install (see packages/sudo/files/README.txt)."
fi

echo "sudo install: done."
