#!/usr/bin/env bash
# packages/brew/export - dump live Homebrew state to packages/brew/Brewfile (same dir as this script; --output is that dir).

set -euo pipefail

# shellcheck source=../../packages/lib.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)/packages/lib.sh"

dotfiles_parse_output_arg "$@"
dotfiles_require_output_dir "$DOTFILES_OUTPUT_DIR"

if ! command -v brew >/dev/null 2>&1; then
  echo "brew not found; skipping export." >&2
  exit 0
fi

ensure_brew_shellenv

HOMEBREW_NO_AUTO_UPDATE=1 brew bundle dump --file "$DOTFILES_OUTPUT_DIR/Brewfile" --force

echo "brew export: $DOTFILES_OUTPUT_DIR/Brewfile"
