#!/usr/bin/env bash
# packages/hosts/install - append a marked block from snippets to /etc/hosts (requires sudo).

set -euo pipefail

export DOTFILES_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
snippets_dir="$DOTFILES_ROOT/packages/hosts/snippets"
marker_begin="# DOTFILES_HOSTS_BEGIN"
marker_end="# DOTFILES_HOSTS_END"

if [[ ! -d "$snippets_dir" ]]; then
  echo "hosts install: no snippets directory."
  exit 0
fi

if [[ -r /etc/hosts ]] && grep -qF "$marker_begin" /etc/hosts; then
  echo "hosts install: markers already present in /etc/hosts; skipping append."
  exit 0
fi

snippet_files=()
shopt -s nullglob
for f in "$snippets_dir"/*; do
  [[ -f "$f" ]] || continue
  base="$(basename "$f")"
  case "$base" in
    README.txt|*.md) continue ;;
  esac
  snippet_files+=("$f")
done
shopt -u nullglob

if [[ "${#snippet_files[@]}" -eq 0 ]]; then
  echo "hosts install: no snippet files to merge."
  exit 0
fi

tmp="$(mktemp)"
{
  echo "$marker_begin"
  for f in "${snippet_files[@]}"; do
    cat "$f"
    echo
  done
  echo "$marker_end"
} >"$tmp"

echo "Appending dotfiles hosts block to /etc/hosts..."
sudo tee -a /etc/hosts <"$tmp" >/dev/null
rm -f "$tmp"

echo "hosts install: done."
