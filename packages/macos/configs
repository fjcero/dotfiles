#!/usr/bin/env bash
# packages/macos/configs - defaults domains for macOS export (grouped by category; sourced by export; --list when run directly).

set -euo pipefail

# --- Global ---
MACOS_DEFAULTS_GLOBAL=(
  "NSGlobalDomain"
)

# --- Trackpad & pointing ---
MACOS_DEFAULTS_POINTING=(
  "com.apple.AppleMultitouchTrackpad"
  "com.apple.driver.AppleBluetoothMultitouch.trackpad"
)

# --- Dock, Finder, desktop & windowing ---
MACOS_DEFAULTS_DESKTOP=(
  "com.apple.dock"
  "com.apple.finder"
  "com.apple.screencapture"
  "com.apple.spaces"
  "com.apple.symbolichotkeys"
)

# --- Menu bar & Control Center ---
MACOS_DEFAULTS_MENUBAR=(
  "com.apple.controlcenter"
  "com.apple.menuextra.clock"
)

# --- Browsers & dev tools ---
MACOS_DEFAULTS_APPS=(
  "com.google.Chrome"
  "com.apple.Terminal"
  "com.apple.dt.Xcode"
)

# Flat list used by export (order follows groups above).
DEFAULTS_DOMAINS=(
  "${MACOS_DEFAULTS_GLOBAL[@]}"
  "${MACOS_DEFAULTS_POINTING[@]}"
  "${MACOS_DEFAULTS_DESKTOP[@]}"
  "${MACOS_DEFAULTS_MENUBAR[@]}"
  "${MACOS_DEFAULTS_APPS[@]}"
)

list_macos_configs() {
  echo "defaults domains (by category):"
  echo
  echo "  Global"
  printf '    %s\n' "${MACOS_DEFAULTS_GLOBAL[@]}"
  echo "  Trackpad & pointing"
  printf '    %s\n' "${MACOS_DEFAULTS_POINTING[@]}"
  echo "  Dock, Finder, desktop & windowing"
  printf '    %s\n' "${MACOS_DEFAULTS_DESKTOP[@]}"
  echo "  Menu bar & Control Center"
  printf '    %s\n' "${MACOS_DEFAULTS_MENUBAR[@]}"
  echo "  Browsers & dev tools"
  printf '    %s\n' "${MACOS_DEFAULTS_APPS[@]}"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  list_macos_configs
fi
