#!/usr/bin/env bash
# packages/macos/export - compare live macOS defaults against packages/macos/defaults.
# Usage: ./packages/macos/export [--output <dir>]
#   Prints drift to stdout. With --output, also writes drift to <dir>/drift.txt.

set -euo pipefail

export_dir=""
[[ "${1:-}" == "--output" || "${1:-}" == "-o" ]] && export_dir="${2:-}"

defaults_file="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/defaults"
drift=0

grep '^defaults write ' "$defaults_file" | while read -r _ _ domain key flag rest; do
  expected="${rest%%#*}"
  expected="${expected%"${expected##*[! ]}"}"  # strip trailing whitespace
  live=$(defaults read "$domain" "$key" 2>/dev/null) || { echo "  NEW  $domain $key $flag $expected"; continue; }
  [[ "$flag" == "-bool" ]] && { [[ "$live" == "1" ]] && live="true" || live="false"; }
  if [[ "$live" != "$expected" ]]; then
    echo "  DIFF $domain $key: install=$expected live=$live"
  fi
done | {
  output=$(cat)
  if [[ -z "$output" ]]; then
    echo "macos export: no drift (install matches live system)."
  else
    echo "macos export: drift detected:"
    echo "$output"
  fi

  if [[ -n "$export_dir" ]]; then
    mkdir -p "$export_dir"
    echo "$output" > "$export_dir/drift.txt"
    echo "wrote: $export_dir/drift.txt"
  fi
}
