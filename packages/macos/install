#!/usr/bin/env bash
# packages/macos/install - apply macOS defaults and optional hostname.
#
# Optional:
#   DOTFILES_HOSTNAME   Set HostName, LocalHostName, and ComputerName (requires sudo).

set -euo pipefail

pkg_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "Configuring macOS defaults..."

# --- Hostname (opt-in, needs sudo) ---
if [[ -n "${DOTFILES_HOSTNAME:-}" ]]; then
  echo "Setting hostname to: $DOTFILES_HOSTNAME (requires sudo)..."
  sudo scutil --set HostName "$DOTFILES_HOSTNAME"
  sudo scutil --set LocalHostName "$DOTFILES_HOSTNAME"
  sudo scutil --set ComputerName "$DOTFILES_HOSTNAME"
  sudo dscacheutil -flushcache
  echo "Hostname set. May need a restart for all services to pick it up."
fi

# Apply defaults from the defaults file
source "$pkg_dir/defaults"

echo "Restarting affected macOS services..."
killall Dock Finder SystemUIServer 2>/dev/null || true

echo "macos install: done. Some changes may still require a logout or restart."
